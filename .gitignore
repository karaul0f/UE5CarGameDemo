# Visual Studio
.vs/
*.suo
*.sln.docstates
*.user
*.userosscache
*.sln.ide/

# Visual Studio generated project files (regenerated by UBT)
*.sln
*.vcxproj
*.vcxproj.filters

# Compiled objects
*.obj
*.pch
*.gch
*.slo
*.lo
*.o

# Libraries
*.lib
*.a
*.la
*.lai
*.so
*.dylib

# Executables (packaged builds should be ignored, but editor exe is in Binaries)
*.exe
*.out
*.app
*.ipa

# UE5: Generated/compiled output — safe to regenerate
Binaries/
Intermediate/
DerivedDataCache/
Plugins/**/Binaries/
Plugins/**/Intermediate/

# UE5: Saved folder (logs, screenshots, autosaves, config cache)
Saved/

# UE5: Build output
Build/
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt
!Build/**/*.ico

# UE5: Precompiled/baked map data (regenerated on cook)
*_BuiltData.uasset

# UE5: Project files regenerated by the engine
*.xcodeproj
*.xcworkspace
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vsconfig

# UE5: Precompiled source art (keep originals, ignore exported)
SourceArt/**/*.png
SourceArt/**/*.tga

# OS metadata
.DS_Store
Thumbs.db
Desktop.ini

# JetBrains Rider
.idea/
*.iml
